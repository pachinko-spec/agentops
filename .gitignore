# Local scratch space for lint/test logs, temp scripts, and disposable artifacts.
/.tmp/
.agentops/.tmp/

# Delegate run logs may include session ids, local paths, stderr, and model output.
.agentops/runs/*
!.agentops/runs/README.md

# Python validation/test caches.
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Ignore the empty root-level Codex marker file while still allowing a future
# project .codex/ directory to be tracked if we intentionally add config there.
/.codex
!/.codex/
!/.codex/**

# Claude Code runtime artifacts (ScheduleWakeup lockfile, plugin state cache).
# Do not commit; recreated by the harness as needed.
/.claude/

# secret artifacts (P1-07)
# Never commit credentials, API keys, signed certs, or local-only env files.
.env
.env.*
*.key
*.pem
credentials*.json
.dev.vars
# NOTE: wrangler.toml itself is configuration (not secret). Do NOT ignore it.
# Wrangler secrets must be set via `wrangler secret put`, never committed.
