# Git hooks / quality gate 用の環境変数雛形です。

# 保護対象ブランチ。スペース区切り。
AGENTOPS_PROTECTED_BRANCHES="main master develop"

# 保護対象ブランチでの commit / push を一時許可する場合のみ 1 にする。
AGENTOPS_ALLOW_PROTECTED=0

# pre-push で実行する検証コマンド。
AGENTOPS_TEST_COMMAND="python3 -m compileall tools"

# テストコマンド未設定でも push を許可する場合のみ 1 にする。
AGENTOPS_ALLOW_NO_TESTS=0

# CLI Wrapper の外部コマンドテンプレート。正式な CLI 仕様は使用時に公式 docs で確認する。
# 使用可能な変数: {to} {role} {model} {model_arg} {effort} {request_file} {run_dir}
# AGENTOPS_CODEX_CMD="codex exec --model {model} --reasoning-effort {effort} -"
# AGENTOPS_CLAUDE_CMD="claude --model {model} --print"
